# AWS
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_DEFAULT_REGION=us-east-1

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#infra-costs

# Budget (optional)
MONTHLY_BUDGET_USD=25000

# Anomaly threshold — alert if a service grows more than this % day-over-day
ANOMALY_THRESHOLD_PCT=100

# Optional: Number of services to show in top movers
TOP_MOVERS_COUNT=5

# Optional: Days to compare against for week-over-week
LOOKBACK_DAYS=7
